{
  "name": "@almostjacked/fitness-tools-mcp",
  "version": "0.3.0",
  "description": "MCP (Model Context Protocol) stdio server for the fitness-tools calculators.",
  "type": "module",
  "bin": {
    "fitness-tools-mcp": "dist/main.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "tsc -p tsconfig.json",
    "prepublishOnly": "node ../../scripts/guard-publish.mjs",
    "start": "node dist/main.js",
    "dev": "tsx watch src/main.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "deploy": "wrangler deploy",
    "build:mcpb": "esbuild src/main.ts --bundle --platform=node --format=esm --outfile=mcpb/server/index.js --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\" && mcpb pack mcpb fitness-tools.mcpb"
  },
  "dependencies": {
    "@almostjacked/fitness-tools": "workspace:*",
    "@hono/mcp": "^0.3.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "hono": "^4.12.23",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "^2.1.2",
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "wrangler": "^4.113.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "author": "AJ Wallace <ajwallacemusic@gmail.com>",
  "homepage": "https://github.com/almostjacked/fitness-tools/tree/main/apps/mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/almostjacked/fitness-tools.git",
    "directory": "apps/mcp"
  },
  "bugs": {
    "url": "https://github.com/almostjacked/fitness-tools/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "fitness",
    "tdee",
    "calculator"
  ],
  "publishConfig": {
    "access": "public"
  }
}

{
  "name": "@almostjacked/fitness-tools",
  "version": "0.1.0",
  "description": "Composable, deterministic fitness calculators. Isomorphic: browser + server.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "./dist/index.js"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "gen:tools": "tsx scripts/gen-tools-table.ts"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "jsdom": "^24.0.0",
    "tsx": "^4.16.0"
  },
  "license": "MIT",
  "author": "AJ Wallace <ajwallacemusic@gmail.com>",
  "homepage": "https://github.com/ajwallacemusic/fitness-tools/tree/main/packages/core#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ajwallacemusic/fitness-tools.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/ajwallacemusic/fitness-tools/issues"
  },
  "keywords": [
    "fitness",
    "health",
    "calculator",
    "bmr",
    "tdee",
    "body-fat",
    "one-rep-max",
    "1rm",
    "macros",
    "nutrition",
    "strength",
    "ffmi",
    "zod",
    "typescript",
    "isomorphic"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}

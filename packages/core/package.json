{
  "name": "@fitness-tools/core",
  "version": "0.1.0",
  "description": "Composable, deterministic fitness calculators. Isomorphic: browser + server.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "sideEffects": ["./dist/index.js"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen:tools": "tsx scripts/gen-tools-table.ts"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "jsdom": "^24.0.0",
    "tsx": "^4.16.0"
  },
  "license": "MIT"
}
